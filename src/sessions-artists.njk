---
layout: base.njk
current: sessions
permalink: /sessions/artists/
title: "Artists: Songs That Found Me at the Right Time"
description: "The artists of Songs That Found Me at the Right Time, from Sharon Van Etten and Bartees Strange to CHAI and Cassandra Jenkins. Each shares the song that found them at the right time."
ogType: website
---
<style>
  .artists-page { padding-block: var(--space-xl); }
  .artists-head { max-width: var(--maxw-prose); margin-bottom: var(--space-lg); }
  .artists-head .eyebrow { display: block; margin: 0 0 var(--space-2xs); }
  .artists-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-sm);
  }
  .artists-intro { font-family: var(--font-body); font-size: var(--fs-lead); line-height: var(--lh-base); color: var(--text); margin: 0; }
  .artists-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: var(--space-md);
  }
  .artists-back:hover { color: var(--accent); }

  .artists-group { margin-top: var(--space-lg); }
  .artists-group__letter {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    color: var(--accent);
    margin: 0 0 var(--space-sm);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--line);
  }
  .artists-list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-2xs); grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .artists-list li { display: flex; }
  .artist-row {
    display: flex;
    flex-direction: column;
    width: 100%;
    text-decoration: none;
    color: inherit;
    padding: var(--space-2xs) 0;
  }
  .artist-row__name {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-h3);
    letter-spacing: var(--tracking-tight);
    line-height: 1.15;
    color: var(--text);
    transition: color var(--transition);
  }
  .artist-row:hover .artist-row__name,
  .artist-row:focus-visible .artist-row__name { color: var(--accent); }
  .artist-row__song { font-family: var(--font-mono); font-size: var(--fs-tiny); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: var(--ink-muted); margin-top: var(--space-3xs); }
</style>

<div class="container artists-page">
  <a class="artists-back" href="/sessions/">&larr; All episodes</a>

  <header class="artists-head">
    <span class="eyebrow">Songs That Found Me at the Right Time</span>
    <h1>The artists</h1>
    <p class="artists-intro">
      Every artist who has shared the song that found them at the right time, in their own words and
      voice. {{ sessions.length }} episodes, alphabetical.
    </p>
  </header>

  {# group by first letter of the artist name #}
  {% set roster = sessions | sort(attribute="artist") %}
  {% set letters = [] %}
  {% for s in roster %}
    {% set L = s.artist | upper | truncate(1, true, "") %}
    {% if L not in letters %}{% set letters = (letters.push(L), letters) %}{% endif %}
  {% endfor %}

  {% for L in letters %}
  <section class="artists-group">
    <p class="artists-group__letter">{{ L }}</p>
    <ul class="artists-list">
      {% for s in roster %}
        {% if (s.artist | upper | truncate(1, true, "")) == L %}
        <li>
          <a class="artist-row" href="{{ s.url }}">
            <span class="artist-row__name">{{ s.artist }}</span>
            {% if s.chose %}<span class="artist-row__song">{{ s.chose }}</span>{% endif %}
          </a>
        </li>
        {% endif %}
      {% endfor %}
    </ul>
  </section>
  {% endfor %}
</div>
