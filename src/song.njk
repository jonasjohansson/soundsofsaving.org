---
layout: base.njk
pagination:
  data: songs
  size: 1
  alias: song
permalink: "{{ song.url }}"
eleventyComputed:
  title: "{{ song.title }}"
  description: "This episode now lives under /sessions/."
  sitemap: false
  robots: "noindex, follow"
  canonicalOverride: "{% set t = '/sessions/' %}{% for s in sessions %}{% if s.youtube_id and s.youtube_id == song.youtube_id %}{% set t = s.url %}{% endif %}{% endfor %}{{ t }}"
---
{# ------------------------------------------------------------------ #
 #  Per-episode redirect: each old /songs/<slug>/ now points at its new
 #  /sessions/<slug>/ home. We match by YouTube id (slugs differ slightly
 #  between the old 6-item list and the new hub), falling back to the
 #  /sessions/ index if no match is found. Canonical + meta-refresh keep
 #  link equity and bookmarks working.
 # ------------------------------------------------------------------ #}
{% set target = canonicalOverride %}
<meta http-equiv="refresh" content="0; url={{ target }}" />
<script>location.replace({{ target | dump | safe }});</script>
<style>
  .moved { padding-block: var(--space-xl); max-width: var(--maxw-prose); }
  .moved .eyebrow { display: block; margin-bottom: var(--space-2xs); }
  .moved h1 { font-family: var(--font-display); font-size: var(--fs-h2); letter-spacing: var(--tracking-tight); margin: 0 0 var(--space-sm); }
  .moved p { font-family: var(--font-body); color: var(--text); }
  .moved a { font-weight: var(--fw-semibold); }
</style>
<div class="container moved">
  <span class="eyebrow">Moved</span>
  <h1>{{ song.artist }} has a new home</h1>
  <p>This episode now lives at <a href="{{ target }}">{{ target }}</a>. Redirecting you there now.</p>
</div>
