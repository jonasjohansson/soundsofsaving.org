---
layout: base.njk
current: about-us
permalink: /about-us/
title: About Us
description: "Our approach: telling the stories of how music and mental health care can save and improve lives, in partnership with artists and young people."
ogType: website
---
{#
  About Us — intro/mission, Why Now (with stats + pullquote), Our Approach,
  Founding Story, Team, Board of Directors, Advisory Board. All copy from
  content/pages/about.json (CMS-editable). Section order mirrors the live site.
#}
{% set a = pages.about %}

<style>
  .about-page { padding-block: var(--space-xl); }
  .about-page h1 { font-size: var(--fs-title); line-height: var(--lh-tight); margin: 0 0 var(--space-md); }
  .about-page h2 { font-size: var(--fs-h2); line-height: var(--lh-tight); margin: 0 0 var(--space-sm); }
  .about-intro { font-size: var(--fs-lead); line-height: var(--lh-base); max-width: var(--maxw-prose); margin: 0 0 var(--space-2xl); }
  .about-section { margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid var(--border); }
  .about-section p { line-height: var(--lh-base); max-width: var(--maxw-prose); }
  .about-section p + p { margin-top: var(--space-sm); }
  .stat-list { max-width: var(--maxw-prose); margin: var(--space-md) 0; padding-left: var(--space-md); }
  .stat-list li { margin-bottom: var(--space-sm); line-height: var(--lh-base); }
  .about-sources { font-size: var(--fs-small); color: var(--text-muted); max-width: var(--maxw-prose); }
  .about-sources p { margin: 0 0 var(--space-2xs); }
  .pullquote {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    margin: var(--space-lg) 0;
    max-width: var(--maxw-prose);
  }
  .pullquote blockquote { font-size: var(--fs-lead); line-height: var(--lh-base); margin: 0 0 var(--space-xs); font-style: italic; }
  .pullquote cite { font-size: var(--fs-small); color: var(--text-muted); font-style: normal; }
  .people-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md) var(--space-lg);
    margin-top: var(--space-lg);
    list-style: none;
    padding: 0;
  }
  .person h3 { font-size: var(--fs-h3); margin: 0 0 var(--space-3xs); }
  .person__role { text-transform: uppercase; letter-spacing: var(--tracking-wide); font-size: var(--fs-tiny); font-weight: var(--fw-semibold); color: var(--accent); margin: 0 0 var(--space-2xs); }
  .person__email { font-size: var(--fs-small); margin: 0 0 var(--space-xs); }
  .person p { line-height: var(--lh-base); font-size: var(--fs-small); margin: 0; }
  .person p + p { margin-top: var(--space-xs); }

  /* Research / Evidence block — the white paper's canonical home. */
  .research {
    background: var(--dusk);
    color: var(--on-dark);
    border-radius: var(--radius);
    padding: var(--space-xl) var(--space-lg);
    margin-top: var(--space-2xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }
  .research__copy { max-width: var(--maxw-prose); }
  .research__eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--fs-tiny);
    color: var(--coral);
    margin: 0 0 var(--space-2xs);
  }
  .research h2 { color: var(--on-dark); font-size: var(--fs-h2); margin: 0 0 var(--space-xs); }
  .research p { color: var(--paper-2); line-height: var(--lh-base); margin: 0; }
  .research .btn--stroke { border-color: var(--paper); color: var(--paper); }
  .research .btn--stroke:hover { background: var(--paper); color: var(--dusk); }

  /* Advisory roster — a consistent name index (no toggles). */
  .roster {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--space-2xs) var(--space-lg);
    margin-top: var(--space-lg);
    list-style: none;
    padding: 0;
  }
  .roster__item {
    font-family: var(--font-display);
    font-weight: var(--fw-medium);
    color: var(--ink);
    padding: var(--space-2xs) 0;
    border-bottom: 1px solid var(--line);
  }

  /* Partners and supporters — linked where known, desaturated, larger. */
  .about-partners { margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid var(--line); }
  .about-partners h2 { font-size: var(--fs-h2); margin: 0 0 var(--space-lg); }
  .partner-grid { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-lg) var(--space-2xl); list-style: none; margin: 0; padding: 0; }
  .partner-grid li { display: flex; }
  .partner-logo { height: 46px; width: auto; filter: grayscale(1); opacity: 0.6; transition: opacity var(--transition); }
  .partner-grid a:hover .partner-logo, .partner-logo:hover { opacity: 1; }
</style>

<div class="container about-page">
  <h1>About Us</h1>
  {% if a.intro %}<p class="about-intro">{{ a.intro }}</p>{% endif %}

  {% if a.why_now %}
  <section class="about-section" aria-label="{{ a.why_now.heading }}">
    <h2>{{ a.why_now.heading }}</h2>
    <p>{{ a.why_now.body }}</p>
    {% if a.why_now.stats.length %}
    <ul class="stat-list">
      {% for s in a.why_now.stats %}<li>{{ s }}</li>{% endfor %}
    </ul>
    {% endif %}
    {% if a.why_now.pullquote %}
    <figure class="pullquote">
      <blockquote>{{ a.why_now.pullquote }}</blockquote>
      {% if a.why_now.pullquote_attribution %}<cite>{{ a.why_now.pullquote_attribution }}</cite>{% endif %}
    </figure>
    {% endif %}
    {% if a.why_now.sources.length %}
    <div class="about-sources">
      {% for src in a.why_now.sources %}<p>{{ src }}</p>{% endfor %}
    </div>
    {% endif %}
  </section>
  {% endif %}

  {% if a.research %}
  <aside class="research" aria-label="{{ a.research.heading }}">
    <div class="research__copy">
      <h2>{{ a.research.heading }}</h2>
      <p>{{ a.research.body | safe }}</p>
    </div>
    {% if a.research.cta %}
    <a class="btn btn--stroke" href="{{ a.research.cta.href }}">{{ a.research.cta.label }}</a>
    {% endif %}
  </aside>
  {% endif %}

  {% if a.founding_story %}
  <section class="about-section" aria-label="{{ a.founding_story.heading }}">
    <h2>{{ a.founding_story.heading }}</h2>
    {% for para in a.founding_story.body.split("\n\n") %}<p>{{ para }}</p>{% endfor %}
  </section>
  {% endif %}

  {% if a.team %}
  <section class="about-section" aria-label="{{ a.team.heading }}">
    <h2>{{ a.team.heading }}</h2>
    <ul class="people-grid">
      {% for m in a.team.members %}
      <li class="person">
        <p class="person__role">{{ m.role }}</p>
        <h3>{{ m.name }}</h3>
        {% if m.email %}<p class="person__email"><a href="mailto:{{ m.email }}">{{ m.email }}</a></p>{% endif %}
        {% for para in m.bio.split("\n\n") %}<p>{{ para }}</p>{% endfor %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if a.board_of_directors %}
  <section class="about-section" aria-label="{{ a.board_of_directors.heading }}">
    <h2>{{ a.board_of_directors.heading }}</h2>
    <ul class="people-grid">
      {% for m in a.board_of_directors.members %}
      <li class="person">
        <h3>{{ m.name }}</h3>
        <p>{{ m.bio }}</p>
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if a.advisory_board %}
  <section class="about-section" aria-label="{{ a.advisory_board.heading }}">
    <h2>{{ a.advisory_board.heading }}</h2>
    {% if a.advisory_board.intro %}<p>{{ a.advisory_board.intro }}</p>{% endif %}
    <ul class="roster">
      {% for m in a.advisory_board.members %}
      <li class="roster__item">{{ m.name }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  {% if pages.community.partners.logos %}
  <section class="about-partners" aria-label="Partners and supporters">
    <h2>Partners and supporters</h2>
    <ul class="partner-grid">
      {% for logo in pages.community.partners.logos %}
      <li>
        {% if logo.url %}<a href="{{ logo.url }}" target="_blank" rel="noopener" title="{{ logo.alt }}"><img class="partner-logo" src="{{ logo.src }}" alt="{{ logo.alt }}" loading="lazy" decoding="async" /></a>{% else %}<img class="partner-logo" src="{{ logo.src }}" alt="{{ logo.alt }}" loading="lazy" decoding="async" />{% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}
</div>
