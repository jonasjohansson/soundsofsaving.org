---
layout: base.njk
current: resources
permalink: /resources/
title: Get Help
description: "A resource finder for mental health support: crisis lines plus a searchable directory of hotlines, therapy, and community services by topic, location, and language."
ogType: website
---
{#
  Get Help — a resource FINDER, not a database dump.

  Structure:
    1. A persistent, hand-curated crisis band (sage-teal --calm) at the very
       top. These four lines are NOT part of the searchable list — they are
       always visible so a person in crisis never has to filter.
    2. A client-side finder over the cleaned content/resources.json (491
       resources): a search box + Topic / Location / Language filters with
       live counts. All cards are rendered server-side as static HTML with
       data-* attributes; a small vanilla-JS script shows/hides them. Works
       with no build step at runtime.
    3. A placeholder for the future "Understanding mental health" learn layer
       (the news explainer articles), wired in later by another agent.

  Data prep: scripts/parse-resources.js -> scripts/normalize-resources.js.
  Loader: src/_data/resources.js. Landing copy: content/pages/get-help.json.
#}
{% set g = pages["get-help"] %}
{# Server-render only the first batch; the rest render client-side from JSON. #}
{% set initialCount = 36 %}

<style>
  /* ---- Get Help uses --calm (sage-teal) as its primary accent ---- */
  .gethelp { padding-block: var(--space-lg) var(--space-2xl); }

  /* ---- Crisis band: impossible to miss, separate from the finder ---- */
  .crisis-band {
    background: var(--accent);
    color: var(--on-dark);
    border-radius: var(--radius);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .crisis-band .eyebrow { color: var(--on-dark); }
  .crisis-band h1 {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    margin: var(--space-2xs) 0 var(--space-xs);
    color: var(--on-dark);
  }
  .crisis-band__intro {
    font-size: var(--fs-lead);
    line-height: var(--lh-base);
    max-width: 60ch;
    margin: 0 0 var(--space-md);
  }
  .crisis-lines { display: grid; gap: var(--space-2xs); list-style: none; margin: 0 0 var(--space-md); padding: 0; }
  .crisis-lines li { font-size: var(--fs-base); line-height: var(--lh-base); }
  .crisis-lines strong { font-weight: var(--fw-semibold); }
  .crisis-lines a {
    color: var(--on-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: var(--fw-medium);
  }
  .crisis-lines a:hover { color: var(--on-dark); opacity: 0.8; }
  .crisis-band__note { font-size: var(--fs-small); margin: 0; opacity: 0.9; }
  .crisis-band__note a { color: var(--on-dark); text-decoration: underline; }

  /* ---- Finder ---- */
  .finder__head { max-width: var(--maxw-prose); margin-bottom: var(--space-md); }
  .finder__head h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-2xs);
  }
  .finder__head p { color: var(--text-muted); line-height: var(--lh-base); margin: 0; }

  .finder__controls {
    position: sticky;
    top: var(--header-h);
    z-index: 5;
    background: var(--bg);
    padding-block: var(--space-sm);
    margin-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .finder__search { position: relative; margin-bottom: var(--space-sm); }
  .finder__search input {
    width: 100%;
    font: inherit;
    font-size: var(--fs-base);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--text);
  }
  .finder__search input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .finder__filters { display: grid; gap: var(--space-sm); grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); align-items: end; }
  .finder__field { display: grid; gap: var(--space-3xs); }
  .finder__field label { color: var(--accent-deep); }
  .finder__field select {
    font: inherit;
    font-size: var(--fs-small);
    padding: var(--space-2xs) var(--space-xs);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--text);
  }
  .finder__field select:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }

  .finder__status {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    font-size: var(--fs-small);
    color: var(--text-muted);
  }
  .finder__count strong { color: var(--text); font-weight: var(--fw-semibold); }
  .finder__reset {
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent-deep);
    background: none;
    border: 1px solid var(--accent);
    border-radius: var(--radius-pill);
    padding: var(--space-3xs) var(--space-sm);
    cursor: pointer;
  }
  .finder__reset:hover { background: var(--accent); color: var(--on-dark); }
  .finder__reset[hidden] { display: none; }

  /* ---- Topic intro (editorial framing when filtered to one topic) ---- */
  .finder__intro {
    border-left: 3px solid var(--accent);
    padding: var(--space-2xs) 0 var(--space-2xs) var(--space-md);
    margin-bottom: var(--space-md);
    color: var(--text-muted);
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    max-width: var(--maxw-prose);
  }
  .finder__intro[hidden] { display: none; }
  .finder__intro strong { color: var(--text); font-weight: var(--fw-semibold); font-style: normal; }

  /* ---- Cards ---- */
  .resource-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .resource-card {
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
  .resource-card[hidden] { display: none; }
  .resource-card__name {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    line-height: var(--lh-tight);
    margin: 0;
  }
  .resource-card__name a { color: var(--text); }
  .resource-card__name a:hover { color: var(--accent-deep); }
  .resource-card__badge {
    color: var(--accent-deep);
  }
  .resource-card p { font-size: var(--fs-small); color: var(--text-muted); line-height: var(--lh-base); margin: 0; }
  .resource-card__tags { display: flex; flex-wrap: wrap; gap: var(--space-3xs); margin-top: var(--space-2xs); }
  .resource-card__tags .tag {
    color: var(--accent-deep);
    background: var(--paper-3);
    border-radius: var(--radius-pill);
    padding: 2px var(--space-2xs);
  }
  .resource-card__meta {
    font-size: var(--fs-small);
    margin-top: auto;
    padding-top: var(--space-xs);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }
  .resource-card__meta a { color: var(--accent-deep); font-weight: var(--fw-medium); text-decoration: underline; text-underline-offset: 2px; }

  .finder__empty {
    text-align: center;
    padding: var(--space-2xl) var(--space-md);
    color: var(--text-muted);
  }
  .finder__empty[hidden] { display: none; }
  .finder__empty h3 { font-family: var(--font-display); font-size: var(--fs-h3); color: var(--text); margin: 0 0 var(--space-2xs); }

  /* ---- Show more (progressive reveal when no filter is active) ---- */
  .finder__more { display: flex; justify-content: center; margin-top: var(--space-lg); }
  .finder__more[hidden] { display: none; }
  .finder__more button {
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent-deep);
    background: none;
    border: 1px solid var(--accent);
    border-radius: var(--radius-pill);
    padding: var(--space-2xs) var(--space-lg);
    cursor: pointer;
  }
  .finder__more button:hover { background: var(--accent); color: var(--on-dark); }
  .finder__more button:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  /* No-JS notice: hidden when JS runs (it removes [hidden]-less .finder__noscript via <noscript>). */
  .finder__noscript {
    border-left: 3px solid var(--coral);
    padding: var(--space-2xs) 0 var(--space-2xs) var(--space-md);
    margin-bottom: var(--space-md);
    color: var(--text-muted);
    font-size: var(--fs-small);
    line-height: var(--lh-base);
    max-width: var(--maxw-prose);
  }

  /* ---- Learn layer ---- */
  .gethelp-learn {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
  }
  .gethelp-learn h2 { font-family: var(--font-display); font-size: var(--fs-h2); margin: 0 0 var(--space-2xs); }
  .gethelp-learn > p { color: var(--text-muted); max-width: var(--maxw-prose); line-height: var(--lh-base); margin-bottom: var(--space-lg); }
  .learn-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .learn-card {
    position: relative;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    transition: border-color var(--transition);
  }
  .learn-card:hover { border-color: var(--accent); }
  /* Stretch the title link across the whole card so it's all clickable. */
  .learn-card__title a::after { content: ""; position: absolute; inset: 0; }
  .learn-card__kind {
    color: var(--accent-deep);
  }
  .learn-card__title { font-family: var(--font-display); font-size: var(--fs-base); line-height: var(--lh-tight); margin: 0; }
  .learn-card__title a { color: var(--ink); }
  .learn-card__title a:hover { color: var(--accent-deep); }
  .learn-card p { font-size: var(--fs-small); color: var(--text-muted); line-height: var(--lh-base); margin: 0; }
</style>

<div class="container gethelp">

  {# ============================================================ #}
  {#  1. CRISIS BAND — persistent, curated, never filtered         #}
  {# ============================================================ #}
  <section class="crisis-band" aria-labelledby="crisis-heading">
    <p class="eyebrow">In crisis</p>
    <h1 id="crisis-heading">{{ g.crisis.heading }}</h1>
    <p class="crisis-band__intro">{{ g.crisis.intro }}</p>
    <ul class="crisis-lines">
      <li>
        <strong>988 Suicide &amp; Crisis Lifeline.</strong>
        Call or text <a href="tel:988">988</a> any time, any day.
      </li>
      <li>
        <strong>Crisis Text Line.</strong>
        Text <strong>HOME</strong> to <a href="sms:741741?&amp;body=HOME">741741</a> to reach a trained counselor.
      </li>
      <li>
        <strong>The Trevor Project.</strong>
        Crisis support for LGBTQ young people. Call <a href="tel:18664887386">1-866-488-7386</a> or text <strong>START</strong> to <a href="sms:678678?&amp;body=START">678678</a>.
      </li>
    </ul>
    <p class="crisis-band__note">{{ g.crisis.not_us_before }}<a href="{{ g.crisis.not_us_link_url }}" target="_blank" rel="noopener">{{ g.crisis.not_us_link_text }}</a>{{ g.crisis.not_us_after }}</p>
  </section>

  {# ============================================================ #}
  {#  2. FINDER — searchable directory of 491 resources            #}
  {# ============================================================ #}
  <section class="finder" aria-labelledby="finder-heading">
    <div class="finder__head">
      <h2 id="finder-heading">{{ g.directory.heading }}</h2>
      {% if g.directory.intro %}<p>{{ g.directory.intro }}</p>{% endif %}
    </div>

    <div class="finder__controls">
      <div class="finder__search">
        <label class="visually-hidden" for="finder-q">Search resources by name or description</label>
        <input type="search" id="finder-q" placeholder="Search by name or keyword (e.g. grief, veterans, teens)" autocomplete="off" />
      </div>

      <div class="finder__filters">
        <div class="finder__field">
          <label class="label" for="finder-topic">Topic</label>
          <select id="finder-topic">
            <option value="">All topics</option>
            {% for c in resources.categories %}<option value="{{ c.slug }}">{{ c.label }} ({{ c.count }})</option>{% endfor %}
          </select>
        </div>
        <div class="finder__field">
          <label class="label" for="finder-location">Location</label>
          <select id="finder-location">
            <option value="">All locations</option>
            {% for l in resources.locations %}<option value="{{ l.slug }}">{{ l.label }} ({{ l.count }})</option>{% endfor %}
          </select>
        </div>
        <div class="finder__field">
          <label class="label" for="finder-language">Language</label>
          <select id="finder-language">
            <option value="">Any language</option>
            {% for lang in resources.languages %}<option value="{{ lang.slug }}">{{ lang.label }} ({{ lang.count }})</option>{% endfor %}
          </select>
        </div>
      </div>

      <div class="finder__status" role="status" aria-live="polite">
        <span class="finder__count"><strong id="finder-shown">{{ resources.all | length }}</strong> of {{ resources.all | length }} resources</span>
        <button type="button" class="finder__reset" id="finder-reset" hidden>Reset filters</button>
      </div>
    </div>

    {# No-JS notice. The crisis band above is always usable; the finder needs
       JS to filter, so spell that out and still server-render a first batch. #}
    <noscript>
      <p class="finder__noscript">
        The search and filters need JavaScript. The crisis lines above are always
        open, and the first {{ initialCount }} of {{ resources.all | length }}
        resources are listed below. Each links out to the organization providing care.
      </p>
    </noscript>

    {# Per-topic editorial intro, swapped in by JS when a single topic is chosen. #}
    <p class="finder__intro" id="finder-intro" hidden></p>

    {# Only the FIRST batch is server-rendered (initialCount). The rest live in
       the compact JSON blob below and are rendered client-side. This is the
       weight saving: full HTML for 491 cards was ~930 KB. #}
    <ul class="resource-list" id="finder-results">
      {% for r in resources.all.slice(0, initialCount) %}
      <li class="resource-card">
        <p class="resource-card__name">
          {% if r.url %}<a href="{{ r.url }}" target="_blank" rel="noopener">{{ r.name }}</a>{% else %}{{ r.name }}{% endif %}
        </p>
        {% if r.national %}<span class="resource-card__badge">National</span>{% endif %}
        {% if r.description %}<p>{{ r.description }}</p>{% endif %}
        {% if r.categories | length %}
        <div class="resource-card__tags" aria-label="Topics">
          {% for c in r.categories %}{% set cat = (resources.categories | selectattr('slug', 'equalto', c) | first) %}<span class="tag">{{ cat.label if cat else c }}</span>{% endfor %}
        </div>
        {% endif %}
        {% if r.phone or r.url %}
        <div class="resource-card__meta">
          {% if r.phone %}<span class="resource-card__phone">Call <a href="tel:{{ r.phone | replace(' ', '') | replace('(', '') | replace(')', '') | replace('-', '') | replace('.', '') }}">{{ r.phone }}</a></span>{% endif %}
          {% if r.url %}<span class="resource-card__site"><a href="{{ r.url }}" target="_blank" rel="noopener">Visit site</a></span>{% endif %}
        </div>
        {% endif %}
      </li>
      {% endfor %}
    </ul>

    <div class="finder__more" id="finder-more" hidden>
      <button type="button" id="finder-more-btn">Show more resources</button>
    </div>

    <div class="finder__empty" id="finder-empty" hidden>
      <h3>No resources match those filters.</h3>
      <p>Try removing a filter or searching a broader term. If you need help now, the crisis lines at the top of this page are always open.</p>
    </div>

    {# Full compact dataset for the client finder (short keys, see resources.js). #}
    <script type="application/json" id="finder-data">{{ resources.compactJSON | safe }}</script>
    <script type="application/json" id="finder-cat-labels">{{ resources.catLabelsJSON | safe }}</script>
  </section>

  {# ============================================================ #}
  {#  3. LEARN LAYER                                                #}
  {#  The former news "explainer" + resource-sheet articles        #}
  {#  (category: learn / resource-sheet / whitepaper), surfaced as  #}
  {#  cards linking to /learn/<slug>/. Driven off news.learn in     #}
  {#  src/_data/news.js — the .md files stay in content/news/.      #}
  {# ============================================================ #}
  {# whitepaper (a-sound-approach) builds at /learn/ but lives on About, so
     it's excluded upstream in news.learnForGetHelp. #}
  {% set learnCards = news.learnForGetHelp %}
  {% if learnCards | length %}
  <section class="gethelp-learn" id="understanding-mental-health" aria-labelledby="learn-heading">
    <p class="eyebrow">Learn</p>
    <h2 id="learn-heading">Understanding mental health</h2>
    <p>
      Short, plain-language explainers and resource sheets, what therapies like
      EMDR and DBT actually involve, how conditions such as dysthymia present,
      and where to turn in a crisis, so the finder above sits next to context,
      not just contacts.
    </p>
    <ul class="learn-grid">
      {% for post in learnCards %}
      <li class="learn-card">
        <span class="learn-card__kind">{% if post.category == "resource-sheet" %}Resource sheet{% else %}Explainer{% endif %}</span>
        <h3 class="learn-card__title"><a href="{{ post.url }}">{{ post.title }}</a></h3>
        {% if post.excerpt %}<p>{{ post.excerpt }}</p>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

</div>

{# ---- Editorial intros per topic. Keep keys = category slugs. ---- #}
<script type="application/json" id="finder-topic-intros">
{
  "addiction": "Support for substance use and recovery, from peer groups to clinical treatment.",
  "anxiety-stress": "Help for managing anxiety, panic, and chronic stress.",
  "community-services": "Local organizations offering wraparound community support.",
  "crisis-services": "Immediate, often 24/7 response for acute mental health crises.",
  "depression": "Treatment and support for depression and persistent low mood.",
  "domestic-violence-sexual-assault": "Confidential support for survivors of domestic violence and sexual assault.",
  "eating-disorders": "Specialized care and support for eating disorders and disordered eating.",
  "health-wellness": "Broader health and wellness services that support mental wellbeing.",
  "hotline": "Phone and text lines you can reach directly when you need to talk.",
  "houselessness": "Housing support and services for people experiencing houselessness.",
  "lgbtq": "Affirming mental health support for LGBTQ+ people.",
  "multilingual": "Services offered in languages beyond English.",
  "suicide-prevention-support": "Suicide prevention, intervention, and loss-survivor support.",
  "support-services": "General support services connecting people to care.",
  "therapy-services": "Therapists, counselors, and clinics offering ongoing treatment.",
  "youth-families": "Mental health support geared to young people and families.",
  "other-general": "General resources that span topics or aren't yet categorized."
}
</script>

<script>
  /* Resource finder — vanilla, no framework.

     The page server-renders only the first BATCH cards; the full 491-record
     dataset is embedded as the compact JSON blob in #finder-data (short keys,
     see src/_data/resources.js). On load we parse it once and take over
     rendering: search + Topic/Location/Language filters run over the full
     dataset and rebuild the visible cards from JSON.

       - No filter active  -> progressive reveal: show `shownLimit` cards and a
                              "Show more" button that adds another BATCH.
       - Any filter active -> render every match (no Show more), with live
                              counts and a clear empty state.

     Matching is plain substring over precomputed lowercased strings, so even a
     full-list pass over 491 records is well under a frame; keystrokes are
     debounced via requestAnimationFrame. */
  (function () {
    var BATCH = {{ initialCount }};
    var q = document.getElementById("finder-q");
    var topic = document.getElementById("finder-topic");
    var loc = document.getElementById("finder-location");
    var lang = document.getElementById("finder-language");
    var reset = document.getElementById("finder-reset");
    var shown = document.getElementById("finder-shown");
    var empty = document.getElementById("finder-empty");
    var intro = document.getElementById("finder-intro");
    var list = document.getElementById("finder-results");
    var more = document.getElementById("finder-more");
    var moreBtn = document.getElementById("finder-more-btn");
    if (!list) return;

    var data = [];
    var catLabels = {};
    var intros = {};
    try { data = JSON.parse(document.getElementById("finder-data").textContent); } catch (e) { data = []; }
    try { catLabels = JSON.parse(document.getElementById("finder-cat-labels").textContent); } catch (e) { catLabels = {}; }
    try { intros = JSON.parse(document.getElementById("finder-topic-intros").textContent); } catch (e) { intros = {}; }

    var total = data.length;
    var shownLimit = BATCH; // how many of an UNFILTERED list are currently shown

    function tel(p) { return p.replace(/[^0-9+]/g, ""); }
    function esc(s) {
      return String(s).replace(/[&<>"]/g, function (ch) {
        return ch === "&" ? "&amp;" : ch === "<" ? "&lt;" : ch === ">" ? "&gt;" : "&quot;";
      });
    }

    // Build one card's HTML from a compact record.
    function cardHTML(r) {
      var html = '<li class="resource-card">';
      var isNational = (" " + r.l + " ").indexOf(" national ") !== -1;
      html += '<p class="resource-card__name">';
      html += r.u
        ? '<a href="' + esc(r.u) + '" target="_blank" rel="noopener">' + esc(r.n) + "</a>"
        : esc(r.n);
      html += "</p>";
      if (isNational) html += '<span class="resource-card__badge">National</span>';
      if (r.d) html += "<p>" + esc(r.d) + "</p>";
      var cats = r.c ? r.c.split(" ").filter(Boolean) : [];
      if (cats.length) {
        html += '<div class="resource-card__tags" aria-label="Topics">';
        for (var i = 0; i < cats.length; i++) {
          html += '<span class="tag">' + esc(catLabels[cats[i]] || cats[i]) + "</span>";
        }
        html += "</div>";
      }
      if (r.p || r.u) {
        html += '<div class="resource-card__meta">';
        if (r.p) html += '<span class="resource-card__phone">Call <a href="tel:' + esc(tel(r.p)) + '">' + esc(r.p) + "</a></span>";
        if (r.u) html += '<span class="resource-card__site"><a href="' + esc(r.u) + '" target="_blank" rel="noopener">Visit site</a></span>';
        html += "</div>";
      }
      html += "</li>";
      return html;
    }

    function matches(r, term, t, l, lg) {
      if (term && r.s.indexOf(term) === -1) return false;
      if (t && (" " + r.c + " ").indexOf(" " + t + " ") === -1) return false;
      if (l && (" " + r.l + " ").indexOf(" " + l + " ") === -1) return false;
      if (lg && (" " + r.g + " ").indexOf(" " + lg + " ") === -1) return false;
      return true;
    }

    function render(rows, limit) {
      var n = Math.min(limit, rows.length);
      var html = "";
      for (var i = 0; i < n; i++) html += cardHTML(rows[i]);
      list.innerHTML = html;
    }

    function apply() {
      var term = q.value.trim().toLowerCase();
      var t = topic.value;
      var l = loc.value;
      var lg = lang.value;
      var active = !!(term || t || l || lg);

      var rows = active ? data.filter(function (r) { return matches(r, term, t, l, lg); }) : data;
      var count = rows.length;

      if (active) {
        // Filtered: show every match, no progressive reveal.
        render(rows, count);
        shown.textContent = count;
        more.hidden = true;
      } else {
        // Unfiltered: progressive reveal up to shownLimit.
        if (shownLimit > total) shownLimit = total;
        render(rows, shownLimit);
        shown.textContent = total;
        more.hidden = shownLimit >= total;
      }

      empty.hidden = count !== 0;
      list.hidden = count === 0;

      // Editorial intro: show only when exactly one topic is selected.
      if (t && intros[t]) {
        var label = topic.options[topic.selectedIndex].text.replace(/\s*\(\d+\)\s*$/, "");
        intro.innerHTML = "<strong>" + esc(label) + ".</strong> " + esc(intros[t]);
        intro.hidden = false;
      } else {
        intro.hidden = true;
      }

      reset.hidden = !active;
    }

    var raf = null;
    function schedule() {
      if (raf) return;
      raf = requestAnimationFrame(function () { raf = null; shownLimit = BATCH; apply(); });
    }

    q.addEventListener("input", schedule);
    topic.addEventListener("change", function () { shownLimit = BATCH; apply(); });
    loc.addEventListener("change", function () { shownLimit = BATCH; apply(); });
    lang.addEventListener("change", function () { shownLimit = BATCH; apply(); });
    reset.addEventListener("click", function () {
      q.value = ""; topic.value = ""; loc.value = ""; lang.value = "";
      shownLimit = BATCH;
      apply();
      q.focus();
    });
    moreBtn.addEventListener("click", function () {
      shownLimit += BATCH;
      apply();
    });

    // Allow deep-linking: /resources/?topic=lgbtq, ?location=national, ?q=grief
    var params = new URLSearchParams(location.search);
    if (params.get("q")) q.value = params.get("q");
    if (params.get("topic")) topic.value = params.get("topic");
    if (params.get("location")) loc.value = params.get("location");
    if (params.get("language")) lang.value = params.get("language");

    // Take over rendering from the server-rendered first batch.
    apply();
  })();
</script>
