---
layout: base.njk
current: sessions
pagination:
  data: sessions
  size: 1
  alias: session
permalink: "{{ session.url }}"
eleventyComputed:
  title: "{{ session.title }}"
  description: "{{ session.excerpt }}"
  ogType: "video.other"
  ogImage: "{{ session.thumbnail }}"
  ogImageW: "{{ session.dims.width if session.dims else '' }}"
  ogImageH: "{{ session.dims.height if session.dims else '' }}"
  ogImageAlt: "{{ session.title }}"
---
{# prev / next within the same sorted sessions array #}
{% set idx = null %}
{% for s in sessions %}{% if s.slug == session.slug %}{% set idx = loop.index0 %}{% endif %}{% endfor %}
{% set prev = sessions[idx - 1] if idx and idx > 0 else null %}
{% set next = sessions[idx + 1] if (idx != null and idx < (sessions.length - 1)) else null %}

<style>
  .session-detail { padding-block: var(--space-lg) var(--space-xl); }
  .session-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--ink-muted);
    text-decoration: none;
    margin-bottom: var(--space-md);
  }
  .session-back:hover { color: var(--accent); }

  .session-detail__head { max-width: var(--maxw-prose); margin-bottom: var(--space-md); }
  .session-eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--fs-tiny);
    color: var(--accent);
    margin: 0 0 var(--space-2xs);
  }
  .session-detail__head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-title);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    margin: 0;
  }
  .session-detail__head .session-song {
    font-family: var(--font-body);
    font-size: var(--fs-h3);
    color: var(--text-muted);
    margin: var(--space-2xs) 0 0;
    font-weight: var(--fw-regular);
  }

  .session-embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: var(--space-md) 0 var(--space-lg);
    background: var(--dusk);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .session-embed iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; display: block; }

  .session-body { max-width: var(--maxw-prose); }

  /* Song metadata, integrated under the title (replaces the aside card). */
  .session-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md) var(--space-lg);
    margin: var(--space-md) 0 0;
    padding: 0;
  }
  .session-meta > div { display: flex; flex-direction: column; gap: 2px; }
  .session-meta dt {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .session-meta dd { margin: 0; font-family: var(--font-body); color: var(--text); }

  .session-story-col { max-width: var(--maxw-prose); }
  .session-pull {
    font-family: var(--font-body);
    font-size: var(--fs-lead);
    line-height: 1.5;
    font-style: italic;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    margin: 0 0 var(--space-lg);
  }
  .session-story { font-family: var(--font-body); font-size: var(--fs-base); line-height: var(--lh-base); color: var(--text); }
  .session-story p { margin: 0 0 var(--space-sm); }
  .session-watch {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
  }
  .session-watch:hover { text-decoration: underline; }

  /* — prev / next — */
  .session-nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--line);
  }
  .session-nav a {
    display: grid;
    gap: var(--space-3xs);
    max-width: 45%;
    text-decoration: none;
  }
  .session-nav a.next { text-align: right; margin-left: auto; }
  .session-nav .dir {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--ink-faint);
  }
  .session-nav .name { font-family: var(--font-display); font-weight: var(--fw-semibold); color: var(--text); }
  .session-nav a:hover .name { color: var(--accent); }
</style>

<article class="container session-detail">
  <a class="session-back" href="/sessions/">&larr; Songs That Found Me at the Right Time</a>

  <header class="session-detail__head">
    <h1>{{ session.artist }}</h1>
    {% if session.chose %}<p class="session-song">The song: {{ session.chose }}</p>{% endif %}
    <dl class="session-meta">
      {% if session.song_title %}<div><dt>Song</dt><dd>{{ session.song_title }}</dd></div>{% endif %}
      {% if session.covers %}<div><dt>Written by</dt><dd>{{ session.covers }}</dd></div>{% endif %}
      {% if session.date %}<div><dt>Released</dt><dd>{{ session.date | postDate }}</dd></div>{% endif %}
    </dl>
  </header>

  {% if session.youtube_id %}
  <div class="session-embed">
    <iframe
      src="{{ session.embed_url }}"
      title="{{ session.title }}"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen></iframe>
  </div>
  {% endif %}

  <div class="session-body">
    {% if session.pull_quote %}<blockquote class="session-pull">{{ session.pull_quote }}</blockquote>{% endif %}
    {% if session.storyHtml %}<div class="session-story prose">{{ session.storyHtml | safe }}</div>{% endif %}
    {% if session.youtube_url %}
    <a class="session-watch" href="{{ session.youtube_url }}" target="_blank" rel="noopener">Watch on YouTube &rarr;</a>
    {% endif %}
  </div>

  <nav class="session-nav" aria-label="Episode navigation">
    {% if prev %}<a class="prev" href="{{ prev.url }}"><span class="dir">&larr; Previous</span><span class="name">{{ prev.artist }}</span></a>{% endif %}
    {% if next %}<a class="next" href="{{ next.url }}"><span class="dir">Next &rarr;</span><span class="name">{{ next.artist }}</span></a>{% endif %}
  </nav>
</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": {{ session.title | dump | safe }},
  "description": {{ session.excerpt | dump | safe }},
  {% if session.thumbnail %}"thumbnailUrl": [{{ (session.thumbnail | absImg) | dump | safe }}],{% endif %}
  {% if session.date %}"uploadDate": {{ session.date | dump | safe }},{% endif %}
  "embedUrl": {{ session.embed_url | dump | safe }},
  "contentUrl": {{ session.youtube_url | dump | safe }},
  "publisher": { "@type": "Organization", "name": "Sounds of Saving", "url": {{ site.origin | dump | safe }} }
}
</script>
