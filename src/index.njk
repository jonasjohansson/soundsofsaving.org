---
layout: base.njk
current: home
permalink: /
title: ""
heroOverlayNav: true
eleventyComputed:
  description: "{{ settings.seo.home or settings.meta_description }}"
---
{#
  Home — message-first, "Liner Notes" design system. Section order:
  1. Hero        — positioning line over a real full-color artist still + one CTA
  2. Four doors  — Sessions / Get Help / Educators / Donate, on paper
  3. Featured    — the first featured session, song-card treatment
  4. Marquee     — artist names/thumbnails strip -> /sessions/artists/
  5. Get Help    — sage-teal band, 500+ resources + the 988 crisis line
  6. Stories     — latest from news.stories

  Pulls from: sessions.js (featured episode, marquee, count), news.stories,
  resources count (static teaser), settings (donate_url, crisis_line).
  The old color-overlay video hero / animated logo / Donate-first ask are gone;
  a single full-color session still re-personalizes the page.
#}
{% set featured = sessions | selectattr("featured") | first %}
{% set hero = featured or sessions | first %}
{% set storyList = news.stories %}

<style>
  /* — 1. Hero — full-color artist still, one positioning line, one CTA ——— */
  .home-hero {
    position: relative;
    min-height: min(92vh, 760px);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--ink);
    color: var(--paper);
  }
  .home-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    z-index: 0;
  }
  /* Restrained legibility gradient — bottom + left only, keeps the image
     essentially full-color (the whole point: re-personalize, no flat wash). */
  .home-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(rgba(20,16,28,0.24), rgba(20,16,28,0.24)),
      linear-gradient(180deg, rgba(20,16,28,0.24) 0%, rgba(20,16,28,0) 24%),
      linear-gradient(0deg, rgba(20,16,28,0.84) 0%, rgba(20,16,28,0.6) 34%, rgba(20,16,28,0.28) 58%, rgba(20,16,28,0) 82%);
  }
  .home-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-block: var(--space-2xl);
  }
  .home-hero__eyebrow { color: var(--paper); margin: 0 0 var(--space-sm); }
  .home-hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-mega);
    line-height: var(--lh-tight);
    font-weight: var(--fw-semibold);
    margin: 0;
    max-width: 16ch;
    color: var(--paper);
    text-wrap: balance;
  }
  .home-hero__sub {
    margin: var(--space-md) 0 0;
    max-width: 60ch;
    font-size: var(--fs-lead);
    line-height: var(--lh-base);
    color: var(--paper);
  }
  .home-hero__sub .sos-name { text-transform: uppercase; letter-spacing: 0.04em; }
  .home-hero__ctas { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-lg); }
  .home-hero__ghost { border-color: var(--paper); color: var(--paper); }
  .home-hero__ghost:hover { background: var(--paper); color: var(--ink); }
  .home-hero__credit {
    margin: var(--space-md) 0 0;
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--paper);
    opacity: 0.78;
  }

  /* — Shared section heads ——————————————————————————————————————— */
  .home-head { max-width: var(--maxw-prose); margin-bottom: var(--space-lg); }
  .home-head__title { font-family: var(--font-display); font-size: var(--fs-title); line-height: var(--lh-tight); margin: var(--space-2xs) 0 0; }
  .home-head__intro { font-size: var(--fs-lead); line-height: var(--lh-base); color: var(--text-muted); margin: var(--space-sm) 0 0; }
  .home-more {
    display: inline-block;
    margin-top: var(--space-lg);
    color: var(--accent);
    font-weight: var(--fw-semibold);
  }
  .home-more:hover { text-decoration: underline; }

  /* — 2. Support line + four doors ———————————————————————————————— */
  .doors-line {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    line-height: var(--lh-tight);
    margin: 0 0 var(--space-lg);
    max-width: 24ch;
    text-wrap: balance;
  }
  .doors {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (max-width: 1000px) { .doors { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 460px) { .doors { grid-template-columns: 1fr; } }
  .doors > li { display: flex; }
  .door {
    display: block;
    width: 100%;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-md);
    background: var(--paper);
    transition: border-color var(--transition), background var(--transition);
  }
  .door:hover,
  .door:focus-visible { border-color: var(--accent); }
  .door__title { font-family: var(--font-display); font-size: var(--fs-h3); margin: var(--space-2xs) 0 var(--space-3xs); }
  .door__copy { color: var(--text-muted); margin: 0; line-height: var(--lh-base); }

  /* — 3. Featured session ———————————————————————————————————————— */
  .featured {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
  }
  @media (max-width: 720px) { .featured { grid-template-columns: 1fr; } }
  .featured__media {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-alt);
  }
  .featured__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .featured__play {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--paper);
  }
  .featured__play svg { width: 64px; height: 64px; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.55)); opacity: 0.95; }
  .featured__artist { font-family: var(--font-display); font-size: var(--fs-h2); line-height: var(--lh-tight); margin: var(--space-2xs) 0 0; }
  .featured__song { font-size: var(--fs-lead); color: var(--text-muted); margin: var(--space-3xs) 0 0; }
  .featured__links { display: flex; flex-direction: column; align-items: flex-start; gap: var(--space-2xs); margin-top: var(--space-md); }
  .featured__links .home-more { margin-top: 0; }

  /* — 4. Artist marquee —————————————————————————————————————————— */
  .marquee {
    display: flex;
    gap: var(--space-md);
    overflow-x: auto;
    padding-block: var(--space-2xs) var(--space-sm);
    margin: 0;
    list-style: none;
    scrollbar-width: thin;
    -webkit-overflow-scrolling: touch;
  }
  .marquee__item { flex: 0 0 auto; }
  .marquee__link { display: block; width: 150px; text-decoration: none; color: inherit; }
  .marquee__thumb {
    aspect-ratio: 1 / 1;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-alt);
    margin-bottom: var(--space-2xs);
  }
  .marquee__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .marquee__name { font-size: var(--fs-small); font-weight: var(--fw-medium); line-height: 1.25; margin: 0; }

  /* — 6. Stories ————————————————————————————————————————————————— */
  .stories {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .story {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--paper);
    transition: border-color var(--transition);
  }
  .story:hover,
  .story:focus-visible { border-color: var(--accent); }
  .story__media { aspect-ratio: 16 / 10; background: var(--bg-alt); overflow: hidden; }
  .story__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .story__body { padding: var(--space-sm) var(--space-md) var(--space-md); }
  .story__date {
    font-family: var(--font-mono);
    font-size: var(--fs-tiny);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 var(--space-3xs);
  }
  .story__title { font-family: var(--font-display); font-size: var(--fs-h3); line-height: 1.3; margin: 0; }
</style>

{# 1. HERO ——————————————————————————————————————————————————————— #}
<section class="home-hero">
  {% if hero.thumbnail %}
  {% set heroBase = hero.thumbnail | replace(".jpg", "") %}
  <img class="home-hero__img media media--full"
       src="{{ heroBase }}-1280.webp"
       srcset="{{ heroBase }}-800.webp 800w, {{ heroBase }}-1280.webp 1280w, {{ heroBase }}-1920.webp 1920w"
       sizes="100vw"
       alt="{{ hero.artist }} performing for Sounds of Saving"
       {% if hero.dims %}width="{{ hero.dims.width }}" height="{{ hero.dims.height }}"{% endif %}
       fetchpriority="high" decoding="async" />
  {% endif %}
  <div class="home-hero__scrim" aria-hidden="true"></div>
  <div class="home-hero__inner">
    <div class="container">
      <h1 class="home-hero__title">Find hope in music.</h1>
      <p class="home-hero__sub"><span class="sos-name">Sounds of Saving</span> is a music and mental health nonprofit.<br>For everyone, with young people at heart.</p>
      <div class="home-hero__ctas">
        <a class="btn btn--primary" href="/sessions/">Watch a Session</a>
        <a class="btn btn--stroke home-hero__ghost" href="/about-us/">About Sounds of Saving</a>
      </div>
      <p class="home-hero__credit">{% if hero.artist %}Pictured: {{ hero.artist }}{% if hero.song_title %}, &ldquo;{{ hero.song_title }}&rdquo;{% endif %}{% endif %}</p>
    </div>
  </div>
</section>

{# 2. SUPPORT LINE + FOUR DOORS ————————————————————————————————— #}
<section class="section">
  <div class="container">
    <p class="doors-line">Open to everyone. Always free.</p>
    <ul class="doors">
      <li>
        <a class="door" href="/sessions/">
          <p class="label">The films</p>
          <h2 class="door__title">Sessions</h2>
          <p class="door__copy">Artists play the songs that carried them, and tell you why.</p>
        </a>
      </li>
      <li>
        <a class="door" href="/resources/">
          <p class="label">Find a resource</p>
          <h2 class="door__title">Get Help</h2>
          <p class="door__copy">Search vetted mental-health support near you.</p>
        </a>
      </li>
      <li>
        <a class="door" href="/educators/">
          <p class="label">Bring it to your school</p>
          <h2 class="door__title">Educators</h2>
          <p class="door__copy">Free curriculum that opens conversations through music.</p>
        </a>
      </li>
      <li>
        <a class="door" href="{{ settings.donate_url }}" target="_blank" rel="noopener">
          <p class="label">Support the work</p>
          <h2 class="door__title">Donate</h2>
          <p class="door__copy">Keep every session and resource free for the people who need it.</p>
        </a>
      </li>
    </ul>
  </div>
</section>

{# 3. FEATURED SESSION ——————————————————————————————————————————— #}
{% if featured %}
<section class="section section--alt">
  <div class="container">
    <header class="home-head">
      <p class="eyebrow">Featured Session</p>
      <h2 class="home-head__title">Songs that found them<br>at the right time</h2>
    </header>
    <div class="featured">
      <a class="featured__media" href="{{ featured.url }}" aria-label="Watch {{ featured.artist }}{% if featured.song_title %}, {{ featured.song_title }}{% endif %}">
        {% if featured.thumbnail %}
        {% set fBase = featured.thumbnail | replace(".jpg", "") %}
        <img class="media media--full"
             src="{{ fBase }}-800.webp"
             srcset="{{ fBase }}-800.webp 800w, {{ fBase }}-1280.webp 1280w"
             sizes="(max-width: 720px) 92vw, 700px"
             alt="{{ featured.artist }}"
             {% if featured.dims %}width="{{ featured.dims.width }}" height="{{ featured.dims.height }}"{% endif %}
             loading="lazy" decoding="async" />
        {% endif %}
        <span class="featured__play" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </span>
      </a>
      <div>
        <p class="featured__artist">{{ featured.artist }}</p>
        {% if featured.song_title %}<p class="featured__song">{{ featured.song_title }}{% if featured.covers %} ({{ featured.covers }}){% endif %}</p>{% endif %}
        <p class="featured__links">
          <a class="home-more" href="/sessions/">See all {{ sessions.length }} sessions &rarr;</a>
          <a class="home-more" href="/sessions/artists/">Browse every artist &rarr;</a>
        </p>
      </div>
    </div>
  </div>
</section>
{% endif %}

{# STORIES ————————————————————————————————————————————————————— #}
{% if storyList.length %}
<section class="section section--alt">
  <div class="container">
    <header class="home-head">
      <p class="eyebrow">Stories</p>
      <h2 class="home-head__title">Voices on music and mental health</h2>
    </header>
    <ul class="stories">
      {% for post in storyList %}
      {% if loop.index <= 6 %}
      <li>
        <a class="story" href="{{ post.url }}">
          {% if post.image %}
          <span class="story__media">
            {% respImg post.image, { alt: "", className: "media media--full", sizes: "(max-width: 640px) 92vw, (max-width: 1100px) 45vw, 300px", width: post.dims.width if post.dims else null, height: post.dims.height if post.dims else null } %}
          </span>
          {% else %}
          <span class="story__media" aria-hidden="true"></span>
          {% endif %}
          <span class="story__body">
            <p class="story__date"><time datetime="{{ post.date }}">{{ post.date | postDate }}</time></p>
            <h3 class="story__title">{{ post.title }}</h3>
          </span>
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}

{# Randomize the hero + featured session on each page load (client-side). #}
<script id="session-pool" type="application/json">
{%- set pool = [] -%}
{%- for s in sessions -%}
  {%- if s.thumbnail -%}
    {%- set _ = pool.push({ "artist": s.artist, "song": s.song_title, "base": (s.thumbnail | replace(".jpg", "")), "url": s.url, "kind": s.kind }) -%}
  {%- endif -%}
{%- endfor -%}
{{ pool | dump | safe }}
</script>
<script>
  (function () {
    var el = document.getElementById("session-pool");
    if (!el) return;
    var all;
    try { all = JSON.parse(el.textContent); } catch (e) { return; }
    if (!all.length) return;
    var pick = function (arr) { return arr[Math.floor(Math.random() * arr.length)]; };
    var produced = all.filter(function (s) { return s.kind !== "favorite" && s.kind !== "short"; });
    if (!produced.length) produced = all;
    var h = pick(produced);
    var hImg = document.querySelector(".home-hero__img");
    var hCredit = document.querySelector(".home-hero__credit");
    if (hImg && h.base) {
      hImg.srcset = h.base + "-800.webp 800w, " + h.base + "-1280.webp 1280w, " + h.base + "-1920.webp 1920w";
      hImg.src = h.base + "-1280.webp";
      hImg.alt = h.artist + " performing for Sounds of Saving";
    }
    if (hCredit) { hCredit.textContent = "Pictured: " + h.artist + (h.song ? ", “" + h.song + "”" : ""); }
    var withSong = all.filter(function (s) { return s.song; });
    var f = pick(withSong.length ? withSong : all);
    var fImg = document.querySelector(".featured__media img");
    var fLink = document.querySelector(".featured__media");
    var fArtist = document.querySelector(".featured__artist");
    var fSong = document.querySelector(".featured__song");
    if (fImg && f.base) {
      fImg.srcset = f.base + "-800.webp 800w, " + f.base + "-1280.webp 1280w";
      fImg.src = f.base + "-800.webp";
      fImg.alt = f.artist;
    }
    if (fLink && f.url) { fLink.setAttribute("href", f.url); }
    if (fArtist) { fArtist.textContent = f.artist; }
    if (fSong) { fSong.textContent = f.song || ""; fSong.style.display = f.song ? "" : "none"; }
  })();
</script>
